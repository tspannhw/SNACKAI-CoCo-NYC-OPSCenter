# =============================================================================
# NYC Operations Command Center - Snowflake Configuration
# =============================================================================
# Copy this file to .env.local and configure your authentication method.
# The app supports 5 authentication methods (in order of precedence):
#
# 1. OAuth Token (SPCS) - Auto-detected from /snowflake/session/token
# 2. Key-Pair Authentication - Set SNOWFLAKE_PRIVATE_KEY or SNOWFLAKE_PRIVATE_KEY_PATH
# 3. PAT (Programmatic Access Token) - Set SNOWFLAKE_PAT
# 4. Password Authentication - Set SNOWFLAKE_PASSWORD
# 5. External Browser SSO - Default fallback (not supported in server context)
# =============================================================================

# Required for all methods
SNOWFLAKE_ACCOUNT=your-account
SNOWFLAKE_USER=your-username
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=DEMO
SNOWFLAKE_SCHEMA=DEMO

# =============================================================================
# OPTION 1: OAuth (SPCS Deployment)
# =============================================================================
# No configuration needed - OAuth token is auto-injected at /snowflake/session/token
# SNOWFLAKE_HOST is also auto-set in SPCS environment

# =============================================================================
# OPTION 2: Key-Pair Authentication (JWT)
# =============================================================================
# Generate key pair: openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out rsa_key.p8 -nocrypt
# Register public key in Snowflake: ALTER USER your-user SET RSA_PUBLIC_KEY='...'

# Option A: Path to private key file
#SNOWFLAKE_PRIVATE_KEY_PATH=s

# Option B: Private key content (replace newlines with \n)
# SNOWFLAKE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBA...\n-----END PRIVATE KEY-----"

# =============================================================================
# OPTION 3: PAT (Programmatic Access Token)
# =============================================================================
# Create PAT in Snowsight: User Menu > My Profile > Programmatic Access Tokens
# SNOWFLAKE_PAT=your-programmatic-access-token

# =============================================================================
# OPTION 4: Password Authentication
# =============================================================================
# SNOWFLAKE_PASSWORD=your-password

# =============================================================================
# OPTION 5: External Browser SSO
# =============================================================================
# Default fallback - but NOT supported in server/API context
# Works only for CLI tools that can open a browser
